<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Lumina.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Lumina.App.Views"
    Title="Lumina"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Lumina">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="ShellNav"
            Grid.Row="1"
            AlwaysShowHeader="False"
            CompactModeThresholdWidth="0"
            CompactPaneLength="48"
            ExpandedModeThresholdWidth="1008"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            OpenPaneLength="336"
            PaneDisplayMode="Auto"
            PaneTitle="Lumina"
            SelectionChanged="ShellNav_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="LocationsNavItem"
                    Content="Locations"
                    Tag="locations">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Tags"
                    Tag="tags">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8EC;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneCustomContent>
                <Frame x:Name="SidebarFrame" />
            </NavigationView.PaneCustomContent>

            <NavigationView.Content>
                <views:FileExplorerView />
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Window>
