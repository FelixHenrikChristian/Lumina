<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Lumina.App.Views.TagSidebarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Lumina.App.Controls"
    xmlns:converters="using:Lumina.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    VerticalAlignment="Stretch"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />
    </Page.Resources>

    <Grid
        Padding="16"
        VerticalAlignment="Stretch"
        Background="Transparent"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="20"
                FontWeight="SemiBold"
                Text="Tags" />

            <Button
                Grid.Column="1"
                Width="34"
                Height="30"
                Padding="0"
                IsEnabled="{Binding CanAddGroup}">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Click="AddGroup_Click"
                            Text="Add tag group">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Add" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Click="ClearTags_Click"
                            IsEnabled="{Binding CanClearTags}"
                            Text="Clear tags">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Delete" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
                <FontIcon
                    FontSize="14"
                    Glyph="&#xE712;" />
            </Button>
        </Grid>

        <InfoBar
            Grid.Row="1"
            IsOpen="{Binding HasError}"
            Message="{Binding ErrorMessage}"
            Severity="Error"
            Title="Tag error"
            Visibility="{Binding ErrorVisibility}" />

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{Binding BusyVisibility}">
            <ProgressRing
                Width="32"
                Height="32"
                IsActive="{Binding IsBusy}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Loading tags..." />
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{Binding EmptyStateVisibility}">
            <SymbolIcon Symbol="Tag" />
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="No tag groups yet" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="Create a group before adding tags." />
        </StackPanel>

        <ScrollViewer
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalAlignment="Stretch"
            VerticalScrollMode="Enabled"
            VerticalScrollBarVisibility="Auto"
            Visibility="{Binding TagGroupListVisibility}">
            <ItemsControl
                HorizontalAlignment="Stretch"
                ItemsSource="{Binding TagGroups}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander
                            MinWidth="280"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            IsExpanded="True">
                            <Expander.Header>
                                <Grid
                                    MinWidth="220"
                                    HorizontalAlignment="Stretch"
                                    RightTapped="GroupHeader_RightTapped"
                                    Tag="{Binding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Expander.Header>

                            <Border
                                Background="Transparent"
                                HorizontalAlignment="Stretch"
                                RightTapped="GroupContent_RightTapped"
                                Tag="{Binding}">
                                <StackPanel Spacing="0">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Description}"
                                        TextWrapping="WrapWholeWords"
                                        Visibility="{Binding DescriptionVisibility}" />

                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="No tags in this group."
                                        Visibility="{Binding EmptyTagsVisibility}" />

                                    <ItemsControl
                                        HorizontalAlignment="Stretch"
                                        ItemsSource="{Binding Tags}"
                                        Visibility="{Binding TagsVisibility}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <controls:WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Margin="0,0,6,6"
                                                    Padding="10,5"
                                                    Background="{Binding Color, Converter={StaticResource HexColorToBrushConverter}}"
                                                    CornerRadius="4"
                                                    RightTapped="TagChip_RightTapped">
                                                    <TextBlock
                                                        Foreground="{Binding TextColor, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#ffffff}"
                                                        Text="{Binding Name}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
