<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Lumina.App.Views.FileExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Lumina.App.Controls"
    xmlns:converters="using:Lumina.App.Converters"
    xmlns:viewModels="using:Lumina.App.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:services="using:Lumina.App.Services"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:HexColorToBrushConverter x:Key="HexColorToBrushConverter" />

        <Style x:Key="ExplorerNavigationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame
                                                    KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames
                                                Storyboard.TargetName="Root"
                                                Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame
                                                    KeyTime="0"
                                                    Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ContentPresenter"
                                                Storyboard.TargetProperty="Opacity"
                                                To="0.38"
                                                Duration="0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="ExplorerCommandIconButtonStyle"
            BasedOn="{StaticResource ExplorerNavigationButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
        </Style>

        <Style
            x:Key="ExplorerCommandTextButtonStyle"
            BasedOn="{StaticResource ExplorerNavigationButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="ExplorerCommandContainerStyle" TargetType="AppBarElementContainer">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="InlineRenameTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="20" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="{ThemeResource TextControlBackground}" />
            <Setter Property="BorderBrush" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="SearchRelativePathButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="Background" Value="{ThemeResource ApplicationPageBackgroundThemeBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                MinHeight="54"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,8,16,8">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition MinWidth="220" Width="*" />
                        <ColumnDefinition MinWidth="220" Width="320" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Click="BackButton_Click"
                        IsEnabled="{Binding CanNavigateBack}"
                        Style="{StaticResource ExplorerNavigationButtonStyle}"
                        services:Localization.ToolTipKey="Back">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xE72B;" />
                    </Button>

                    <Button
                        Grid.Column="1"
                        Click="ForwardButton_Click"
                        IsEnabled="{Binding CanNavigateForward}"
                        Style="{StaticResource ExplorerNavigationButtonStyle}"
                        services:Localization.ToolTipKey="Forward">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xE72A;" />
                    </Button>

                    <Button
                        Grid.Column="2"
                        Click="UpButton_Click"
                        IsEnabled="{Binding CanNavigateToParent}"
                        Style="{StaticResource ExplorerNavigationButtonStyle}"
                        services:Localization.ToolTipKey="UpOneLevel">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xE74A;" />
                    </Button>

                    <Button
                        Grid.Column="3"
                        Click="RefreshButton_Click"
                        IsEnabled="{Binding CanRefresh}"
                        Style="{StaticResource ExplorerNavigationButtonStyle}"
                        services:Localization.ToolTipKey="Refresh">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xE72C;" />
                    </Button>

                    <Border
                        Grid.Column="4"
                        Height="36"
                        Padding="12,0"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="15"
                                Glyph="&#xE8B7;"
                                VerticalAlignment="Center" />

                            <BreadcrumbBar
                                x:Name="AddressBreadcrumbBar"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                ItemClicked="AddressBreadcrumbBar_ItemClicked"
                                ItemsSource="{Binding BreadcrumbItems}">
                                <BreadcrumbBar.ItemTemplate>
                                    <DataTemplate x:DataType="viewModels:FileExplorerBreadcrumbItemViewModel">
                                        <BreadcrumbBarItem
                                            Content="{Binding}"
                                            AutomationProperties.Name="{Binding Name}">
                                            <BreadcrumbBarItem.ContentTemplate>
                                                <DataTemplate x:DataType="viewModels:FileExplorerBreadcrumbItemViewModel">
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </BreadcrumbBarItem.ContentTemplate>
                                        </BreadcrumbBarItem>
                                    </DataTemplate>
                                </BreadcrumbBar.ItemTemplate>
                            </BreadcrumbBar>
                        </Grid>
                    </Border>

                    <AutoSuggestBox
                        x:Name="SearchBox"
                        Grid.Column="5"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding CanSearch}"
                        KeyboardAcceleratorPlacementMode="Hidden"
                        PlaceholderText="{Binding SearchPlaceholderText}"
                        QueryIcon="Find"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                MinHeight="50"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CommandBar
                        Grid.Column="0"
                        Padding="8,0,8,0"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        DefaultLabelPosition="Collapsed"
                        IsDynamicOverflowEnabled="False"
                        IsOpen="False">
                        <CommandBar.PrimaryCommands>
                        <AppBarElementContainer Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="New"
                                IsEnabled="{Binding CanUseFolderCommands}"
                                Style="{StaticResource ExplorerCommandTextButtonStyle}"
                                services:Localization.ToolTipKey="New">
                                <Button.Flyout>
                                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                        <MenuFlyoutItem
                                            Click="NewFolderMenuItem_Click"
                                            services:Localization.TextKey="Folder">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8B7;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Button.Flyout>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="&#xE710;" />
                                    <TextBlock VerticalAlignment="Center" services:Localization.TextKey="New" />
                                </StackPanel>
                            </Button>
                        </AppBarElementContainer>

                        <AppBarSeparator />

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                x:Name="UndoButton"
                                services:Localization.AutomationNameKey="Undo"
                                Click="UndoButton_Click"
                                IsEnabled="False"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Undo">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE7A7;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                x:Name="RedoButton"
                                services:Localization.AutomationNameKey="Redo"
                                Click="RedoButton_Click"
                                IsEnabled="False"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Redo">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE7A6;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarSeparator />

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="Cut"
                                Click="CutButton_Click"
                                IsEnabled="{Binding CanUseSelectedFileCommands}"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Cut">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE8C6;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="Copy"
                                Click="CopyButton_Click"
                                IsEnabled="{Binding CanUseSelectedFileCommands}"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Copy">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE8C8;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="Paste"
                                Click="PasteButton_Click"
                                IsEnabled="{Binding CanUseFolderCommands}"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Paste">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE77F;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="Rename"
                                Click="RenameButton_Click"
                                IsEnabled="{Binding CanUseSelectedFileCommands}"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Rename">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE8AC;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarElementContainer
                            Width="40"
                            Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="Delete"
                                Click="DeleteButton_Click"
                                IsEnabled="{Binding CanUseSelectedFileCommands}"
                                Style="{StaticResource ExplorerCommandIconButtonStyle}"
                                services:Localization.ToolTipKey="Delete">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE74D;" />
                            </Button>
                        </AppBarElementContainer>

                        <AppBarSeparator />

                        <AppBarElementContainer Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="Sort"
                                Click="SortButton_Click"
                                IsEnabled="{Binding CanSort}"
                                Style="{StaticResource ExplorerCommandTextButtonStyle}"
                                services:Localization.ToolTipKey="Sort">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="&#xE8CB;" />
                                    <TextBlock VerticalAlignment="Center" services:Localization.TextKey="Sort" />
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="10"
                                        Glyph="&#xE70D;" />
                                </StackPanel>
                            </Button>
                        </AppBarElementContainer>

                        </CommandBar.PrimaryCommands>
                    </CommandBar>

                    <CommandBar
                        Grid.Column="1"
                        Padding="8,0,8,0"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        DefaultLabelPosition="Collapsed"
                        IsDynamicOverflowEnabled="False"
                        IsOpen="False">
                        <CommandBar.PrimaryCommands>

                        <AppBarElementContainer Style="{StaticResource ExplorerCommandContainerStyle}">
                            <Button
                                services:Localization.AutomationNameKey="TagFilter"
                                IsEnabled="{Binding CanUseTagFilters}"
                                Style="{StaticResource ExplorerCommandTextButtonStyle}"
                                services:Localization.ToolTipKey="TagFilter">
                                <Button.Flyout>
                                    <Flyout
                                        Opened="TagFilterFlyout_Opened"
                                        Placement="BottomEdgeAlignedRight">
                                        <Grid
                                            Width="320"
                                            MaxHeight="440"
                                            Padding="14"
                                            RowSpacing="12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Spacing="8">
                                                    <FontIcon
                                                        FontFamily="Segoe Fluent Icons"
                                                        FontSize="14"
                                                        Glyph="&#xE71C;" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontWeight="SemiBold"
                                                        services:Localization.TextKey="TagFilter" />
                                                </StackPanel>

                                                <Button
                                                    Grid.Column="1"
                                                    Width="28"
                                                    Height="28"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    Click="ClearTagFiltersButton_Click"
                                                    IsEnabled="{Binding CanClearTagFilters}"
                                                    Style="{StaticResource ExplorerNavigationButtonStyle}"
                                                    services:Localization.ToolTipKey="ClearTagFilter">
                                                    <FontIcon
                                                        FontFamily="Segoe Fluent Icons"
                                                        FontSize="11"
                                                        Glyph="&#xE711;" />
                                                </Button>
                                            </Grid>

                                            <TextBlock
                                                Grid.Row="1"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                services:Localization.TextKey="NoTagsInLibrary"
                                                Visibility="{Binding TagFilterEmptyVisibility}" />

                                            <ScrollViewer
                                                Grid.Row="1"
                                                HorizontalScrollBarVisibility="Disabled"
                                                HorizontalScrollMode="Disabled"
                                                MaxHeight="360"
                                                VerticalScrollBarVisibility="Auto"
                                                VerticalScrollMode="Enabled"
                                                Visibility="{Binding TagFilterGroupListVisibility}">
                                                <ItemsControl ItemsSource="{Binding TagFilterGroups}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="0,0,0,14" Spacing="6">
                                                                <TextBlock
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Text="{Binding Name}"
                                                                    TextTrimming="CharacterEllipsis" />

                                                                <TextBlock
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    services:Localization.TextKey="NoTags"
                                                                    Visibility="{Binding EmptyTagsVisibility}" />

                                                                <ItemsControl
                                                                    ItemsSource="{Binding Tags}"
                                                                    Visibility="{Binding TagsVisibility}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <controls:WrapPanel />
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Button
                                                                                MinWidth="0"
                                                                                MinHeight="0"
                                                                                Margin="0,0,6,6"
                                                                                Padding="9,4"
                                                                                Background="{Binding Color, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#0078d4}"
                                                                                BorderBrush="{Binding Color, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#0078d4}"
                                                                                BorderThickness="1"
                                                                                Click="TagFilterChip_Click"
                                                                                CornerRadius="4"
                                                                                Opacity="{Binding ChipOpacity}"
                                                                                ToolTipService.ToolTip="{Binding Name}">
                                                                                <TextBlock
                                                                                    FontSize="12"
                                                                                    Foreground="{Binding TextColor, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#ffffff}"
                                                                                    Text="{Binding Name}"
                                                                                    TextTrimming="CharacterEllipsis" />
                                                                            </Button>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Flyout>
                                </Button.Flyout>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="&#xE71C;" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding TagFilterButtonText}" />
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="10"
                                        Glyph="&#xE70D;" />
                                </StackPanel>
                            </Button>
                        </AppBarElementContainer>

                    </CommandBar.PrimaryCommands>
                </CommandBar>
                </Grid>
            </Border>
        </Grid>

        <InfoBar
            Grid.Row="1"
            Margin="24,16,24,0"
            IsOpen="{Binding HasError}"
            Message="{Binding ErrorMessage}"
            Severity="Error"
            services:Localization.TitleKey="FolderError"
            Visibility="{Binding ErrorVisibility}" />

        <Grid
            x:Name="FileDropSurface"
            Grid.Row="2"
            Margin="24,16,24,24"
            AllowDrop="True"
            Background="Transparent"
            DragLeave="FileDropSurface_DragLeave"
            DragOver="FileDropSurface_DragOver"
            Drop="FileDropSurface_Drop">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding NoLocationVisibility}">
                <FontIcon
                    FontSize="32"
                    Glyph="&#xE8B7;" />
                <TextBlock
                    HorizontalAlignment="Center"
                FontSize="18"
                FontWeight="SemiBold"
                services:Localization.TextKey="SelectLocation" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                services:Localization.TextKey="ChooseManagedFolderFromLocationsPane" />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding BusyVisibility}">
                <ProgressRing
                    Width="36"
                    Height="36"
                    IsActive="{Binding IsBusy}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                services:Localization.TextKey="LoadingFolder" />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding EmptyStateVisibility}">
                <FontIcon
                    FontSize="32"
                    Glyph="&#xE8B7;" />
                <TextBlock
                    HorizontalAlignment="Center"
                FontSize="18"
                FontWeight="SemiBold"
                services:Localization.TextKey="ThisFolderIsEmpty" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                services:Localization.TextKey="FilesAndFoldersWillAppearHere" />
            </StackPanel>

            <ScrollViewer
                x:Name="FileGridScrollViewer"
                Background="Transparent"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                IsTabStop="True"
                PointerPressed="FileGridScrollViewer_PointerPressed"
                PointerWheelChanged="FileGridScrollViewer_PointerWheelChanged"
                PreviewKeyDown="FileGridScrollViewer_PreviewKeyDown"
                UseSystemFocusVisuals="False"
                VerticalScrollMode="Enabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding FileGridVisibility}">
                <ItemsControl
                    x:Name="FilesItemsControl"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Files}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ExplorerGridPanel
                                ItemWidth="{Binding CardWidth}"
                                MinColumnSpacing="16"
                                RowSpacing="18" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="FileCard"
                                Width="{Binding CardWidth}"
                                Height="{Binding CardHeight}"
                                AllowDrop="True"
                                AutomationProperties.Name="{Binding Name}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CanDrag="True"
                                CornerRadius="6"
                                DoubleTapped="FileCard_DoubleTapped"
                                DragLeave="FileCard_DragLeave"
                                DragOver="FileCard_DragOver"
                                DragStarting="FileCard_DragStarting"
                                Opacity="{Binding CardOpacity}"
                                PointerPressed="FileCard_PointerPressed"
                                PointerReleased="FileCard_PointerReleased"
                                PointerCanceled="FileCard_PointerCanceled"
                                RightTapped="FileCard_RightTapped"
                                Drop="FileCard_Drop"
                                DropCompleted="FileCard_DropCompleted"
                                ToolTipService.ToolTip="{Binding Path=Path}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="48" />
                                    </Grid.RowDefinitions>

                                    <Grid
                                        Margin="0"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                                        <Image
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            IsHitTestVisible="False"
                                            Source="{Binding ThumbnailSource}"
                                            Stretch="Uniform"
                                            Visibility="{Binding ThumbnailVisibility}" />

                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{Binding ThumbnailIconFontSize}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="{Binding IconGlyph}"
                                            Visibility="{Binding IconVisibility}" />

                                        <ItemsControl
                                            x:Name="FileTagsItemsControl"
                                            Margin="8"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            ItemsSource="{Binding TagChips}"
                                            Visibility="{Binding TagVisibility}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        x:Name="FileTagChip"
                                                        CanDrag="True"
                                                        DragStarting="FileTagChip_DragStarting"
                                                        DropCompleted="FileTagChip_DropCompleted"
                                                        MaxWidth="116"
                                                        Margin="0,0,4,4"
                                                        RightTapped="FileTagChip_RightTapped"
                                                        ToolTipService.ToolTip="{Binding Name}">
                                                        <Grid>
                                                            <Border
                                                                Padding="6,2"
                                                                Background="{Binding Color, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#0078d4}"
                                                                BorderBrush="{Binding BorderColor, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#00000000}"
                                                                BorderThickness="{Binding BorderThickness}"
                                                                CornerRadius="4"
                                                                Visibility="{Binding NormalVisibility}">
                                                                <TextBlock
                                                                    FontSize="10"
                                                                    Foreground="{Binding TextColor, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#ffffff}"
                                                                    Text="{Binding Name}"
                                                                    TextTrimming="CharacterEllipsis" />
                                                            </Border>

                                                            <Border
                                                                Padding="6,2"
                                                                Background="{Binding Color, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#0078d4}"
                                                                BorderBrush="{Binding Color, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#0078d4}"
                                                                BorderThickness="1"
                                                                CornerRadius="4"
                                                                Opacity="0.66"
                                                                Visibility="{Binding PreviewVisibility}">
                                                                <TextBlock
                                                                    FontSize="10"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{Binding TextColor, Converter={StaticResource HexColorToBrushConverter}, ConverterParameter=#ffffff}"
                                                                    Text="{Binding Name}"
                                                                    TextTrimming="CharacterEllipsis" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Button
                                            x:Name="RelativePathButton"
                                            Margin="8"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Click="RelativePathButton_Click"
                                            IsTabStop="False"
                                            MaxWidth="{Binding RelativePathBadgeMaxWidth}"
                                            Style="{StaticResource SearchRelativePathButtonStyle}"
                                            ToolTipService.ToolTip="{Binding RelativePathToolTip}"
                                            Visibility="{Binding RelativePathBadgeVisibility}">
                                            <Grid ColumnSpacing="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <FontIcon
                                                    FontFamily="Segoe Fluent Icons"
                                                    FontSize="10"
                                                    Glyph="&#xE8B7;" />

                                                <TextBlock
                                                    Grid.Column="1"
                                                    FontSize="11"
                                                    MaxLines="1"
                                                    Text="{Binding RelativePath}"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="NoWrap" />
                                            </Grid>
                                        </Button>
                                    </Grid>

                                    <Grid
                                        Grid.Row="1"
                                        Padding="10,6,10,7"
                                        RowSpacing="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap"
                                            Visibility="{Binding DisplayInfoVisibility}" />

                                        <Grid
                                            Grid.Row="1"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                MaxLines="1"
                                                Text="{Binding SizeText}"
                                                TextTrimming="CharacterEllipsis" />

                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                MaxLines="1"
                                                Text="{Binding ModifiedText}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>

                                        <TextBox
                                            x:Name="InlineRenameBox"
                                            Margin="-3,-2,-3,0"
                                            VerticalAlignment="Top"
                                            AcceptsReturn="False"
                                            KeyDown="InlineRenameBox_KeyDown"
                                            Loaded="InlineRenameBox_Loaded"
                                            LostFocus="InlineRenameBox_LostFocus"
                                            Style="{StaticResource InlineRenameTextBoxStyle}"
                                            Text="{Binding RenameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Visibility="{Binding RenameEditorVisibility}" />
                                    </Grid>

                                    <Border
                                        Grid.RowSpan="2"
                                        Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Opacity="0.28"
                                        Visibility="{Binding DropTargetVisibility}" />

                                    <Border
                                        Grid.RowSpan="2"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Opacity="0.72"
                                        Visibility="{Binding TagDropTargetVisibility}" />

                                    <Border
                                        Grid.RowSpan="2"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding FocusVisibility}" />

                                    <Border
                                        Grid.RowSpan="2"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding SelectionVisibility}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
