<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Lumina.App.Views.FileExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Lumina.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="SearchBox"
                Header="Search"
                IsEnabled="{Binding CanSearch}"
                PlaceholderText="Search current folder"
                Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextCompositionEnded="SearchBox_TextCompositionEnded"
                TextCompositionStarted="SearchBox_TextCompositionStarted"
                TextChanged="SearchBox_TextChanged" />

            <CommandBar
                Grid.Column="1"
                DefaultLabelPosition="Right"
                IsDynamicOverflowEnabled="False">
                <AppBarButton
                    Click="RefreshButton_Click"
                    Icon="Refresh"
                    IsEnabled="{Binding CanRefresh}"
                    Label="Refresh" />
                <AppBarButton
                    Icon="Sort"
                    IsEnabled="False"
                    Label="Sort" />
            </CommandBar>
        </Grid>

        <TextBlock
            Grid.Row="1"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{Binding BreadcrumbText}"
            TextTrimming="CharacterEllipsis" />

        <InfoBar
            Grid.Row="2"
            IsOpen="{Binding HasError}"
            Message="{Binding ErrorMessage}"
            Severity="Error"
            Title="Folder error"
            Visibility="{Binding ErrorVisibility}" />

        <Grid Grid.Row="3">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding NoLocationVisibility}">
                <FontIcon
                    FontSize="32"
                    Glyph="&#xE8B7;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Select a location" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Choose a managed folder from the Locations pane." />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding BusyVisibility}">
                <ProgressRing
                    Width="36"
                    Height="36"
                    IsActive="{Binding IsBusy}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Loading folder..." />
            </StackPanel>

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                Visibility="{Binding EmptyStateVisibility}">
                <FontIcon
                    FontSize="32"
                    Glyph="&#xE8B7;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="This folder is empty" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Files and folders will appear here." />
            </StackPanel>

            <ScrollViewer
                x:Name="FileGridScrollViewer"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                IsTabStop="True"
                PointerPressed="FileGridScrollViewer_PointerPressed"
                PointerWheelChanged="FileGridScrollViewer_PointerWheelChanged"
                PreviewKeyDown="FileGridScrollViewer_PreviewKeyDown"
                UseSystemFocusVisuals="False"
                VerticalScrollMode="Enabled"
                VerticalScrollBarVisibility="Auto"
                Visibility="{Binding FileGridVisibility}">
                <ItemsControl
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding Files}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:ExplorerGridPanel
                                ItemWidth="{Binding CardWidth}"
                                MinColumnSpacing="16"
                                RowSpacing="18" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="FileCard"
                                Width="{Binding CardWidth}"
                                Height="{Binding CardHeight}"
                                AutomationProperties.Name="{Binding Name}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                DoubleTapped="FileCard_DoubleTapped"
                                PointerPressed="FileCard_PointerPressed"
                                ToolTipService.ToolTip="{Binding Path=Path}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="48" />
                                    </Grid.RowDefinitions>

                                    <Grid
                                        Margin="0"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Segoe Fluent Icons"
                                            FontSize="{Binding ThumbnailIconFontSize}"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="{Binding IconGlyph}" />

                                        <ItemsControl
                                            Margin="8"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            ItemsSource="{Binding Tags}"
                                            Visibility="{Binding TagVisibility}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        MaxWidth="116"
                                                        Margin="0,0,4,4"
                                                        Padding="7,3"
                                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="4">
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                            Text="{Binding}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <Grid
                                        Grid.Row="1"
                                        Padding="10,6,10,7"
                                        RowSpacing="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            MaxLines="1"
                                            Text="{Binding Name}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />

                                        <Grid
                                            Grid.Row="1"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                MaxLines="1"
                                                Text="{Binding SizeText}"
                                                TextTrimming="CharacterEllipsis" />

                                            <TextBlock
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                MaxLines="1"
                                                Text="{Binding ModifiedText}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Grid>

                                    <Border
                                        Grid.RowSpan="2"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding FocusVisibility}" />

                                    <Border
                                        Grid.RowSpan="2"
                                        Background="Transparent"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding SelectionVisibility}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
