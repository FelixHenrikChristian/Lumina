{
  "name": "lumina",
  "private": true,
  "version": "1.1.0",
  "description": "Local, tag-oriented file manager for Windows with a liquid glass interface",
  "author": "FelixHenrikChristian",
  "license": "MIT",
  "homepage": "https://github.com/FelixHenrikChristian/Lumina#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FelixHenrikChristian/Lumina.git"
  },
  "bugs": {
    "url": "https://github.com/FelixHenrikChristian/Lumina/issues"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "node --test \"tests/*.test.ts\"",
    "preview": "vite preview",
    "app:dev": "concurrently -k -s first \"vite --port 5173 --strictPort\" \"wait-on tcp:localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "app:smoke": "cross-env LUMINA_SMOKE=1 electron .",
    "pack:win": "electron-builder --win --publish never",
    "dist": "npm run build && npm run pack:win"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.felixhenrikchristian.lumina",
    "productName": "Lumina",
    "copyright": "Copyright © 2026 FelixHenrikChristian",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "asarUnpack": [
      "electron/windows-shell/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "FelixHenrikChristian",
        "repo": "Lumina"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Lumina-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lumina",
      "uninstallDisplayName": "Lumina ${version}",
      "differentialPackage": true
    },
    "portable": {
      "artifactName": "Lumina-Portable-${version}.${ext}"
    }
  }
}
